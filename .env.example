# ============================================================
# Zymos — Variables de entorno requeridas en producción
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── Base de datos (rol de aplicación — solo DML) ─────────────
# Crear este rol con: psql -U postgres -f db_security.sql
DB_URL=jdbc:postgresql://localhost:5432/trazabilidad_cervezas
DB_USERNAME=zymos_app
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# SSL (si PostgreSQL está en servidor remoto):
# DB_URL=jdbc:postgresql://host:5432/trazabilidad_cervezas?sslmode=require

# ── Flyway (rol con DDL para migraciones) ────────────────────
# Si no se define, usa DB_USERNAME/DB_PASSWORD como fallback.
FLYWAY_USERNAME=zymos_flyway
FLYWAY_PASSWORD=TU_PASSWORD_FLYWAY_AQUI

# ── Usuario administrador inicial de la app ──────────────────
# Solo se crea si no existe en la base de datos.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=TU_PASSWORD_ADMIN_AQUI

# ── JWT ───────────────────────────────────────────────────────
# Mínimo 32 caracteres. Obligatorio en producción.
JWT_SECRET=CAMBIA_POR_UN_SECRETO_LARGO_Y_ALEATORIO
JWT_TTL_HOURS=24

# ── Multi-tenant ──────────────────────────────────────────────
DEFAULT_SUBDOMAIN=default

# ── Branding (opcional — usar valores por defecto si no se necesita) ──
# APP_BRAND_NAME=MiCerveceria
# APP_BRAND_TAGLINE=Sistema de Trazabilidad
# APP_BRAND_LOGO_URL=
# APP_BRAND_COLOR_NAVBAR=#1e293b
# APP_BRAND_COLOR_PRIMARY=#2563eb
# APP_BRAND_COLOR_ACCENT=#0ea5e9

# ── Email / Alertas (opcional) ────────────────────────────────
# Si SMTP_HOST está vacío, las alertas por email se deshabilitan.
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_USERNAME=usuario@tudominio.com
# SMTP_PASSWORD=TU_PASSWORD_SMTP
# SMTP_FROM=noreply@tudominio.com
# APP_BASE_URL=https://tuapp.com

# ── Puerto del servidor (opcional, por defecto 8080) ─────────
# SERVER_PORT=8080
