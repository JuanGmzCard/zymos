# ============================================================
# Alera — Variables de entorno requeridas en producción
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# Base de datos PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/trazabilidad_cervezas
DB_USERNAME=postgres
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# Usuario administrador inicial (solo se crea si no existe)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=TU_PASSWORD_ADMIN_AQUI

# Puerto del servidor (opcional, por defecto 8080)
SERVER_PORT=8080
