<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Perfil de desarrollo: consola con colores ────────────────── -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%logger{25}] %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.alera" level="DEBUG"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>

    <!-- ── Perfil de producción: JSON estructurado (Logstash format) ── -->
    <!-- Compatible con ELK, Loki, Datadog y cualquier log aggregator.  -->
    <!-- StructuredLogEncoder es parte de spring-boot (sin dep extra).  -->
    <springProfile name="prod">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="org.springframework.boot.logging.logback.StructuredLogEncoder">
                <format>logstash</format>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="STDOUT"/>
        </root>

        <logger name="com.alera"                   level="INFO"/>
        <logger name="org.springframework.boot"    level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL"           level="WARN"/>
        <logger name="com.zaxxer.hikari"           level="INFO"/>
        <logger name="org.flywaydb"                level="INFO"/>
    </springProfile>

</configuration>